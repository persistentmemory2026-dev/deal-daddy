# Deal Daddy - Environment Configuration

# Required: Outscraper API Key
# Get yours at: https://outscraper.com
OUTSCRAPER_API_KEY=your_outscraper_api_key_here

# Optional: Email Verification
ZEROBOUNCE_API_KEY=your_zerobounce_key_here

# Optional: AI Enrichment
OPENAI_API_KEY=your_openai_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Database (for future use)
# DATABASE_URL=postgresql://user:pass@localhost/dealdaddy

# Redis (for future queue use)
# REDIS_URL=redis://localhost:6379
